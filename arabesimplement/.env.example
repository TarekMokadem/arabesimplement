# --- Copiez ce fichier en .env et renseignez les valeurs.
#    Ne commitez jamais le fichier .env (déjà dans .gitignore).

# ========== Prisma / PostgreSQL (obligatoire pour données réelles) ==========
# Exemple local : postgresql://USER:PASSWORD@localhost:5432/NOM_BASE?schema=public
# Hébergé gratuit : Neon (neon.tech), Supabase (Database > Connection string), etc.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/arabesimplement?schema=public"

# ========== Session / auth maison (obligatoire avec DATABASE_URL) ==========
# Chaîne secrète d'au moins 32 caractères (ex. openssl rand -base64 32)
SESSION_SECRET=

# Compte admin créé/mis à jour au seed (optionnel)
# ADMIN_SEED_EMAIL=admin@votredomaine.fr
# ADMIN_SEED_PASSWORD=

# ========== Next.js ==========
# Rien à ajouter : Next charge automatiquement .env en local.

# ========== Stripe (paiement réel — optionnel au début) ==========
# Tableau de bord : https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhooks : Developers > Webhooks > endpoint URL .../api/webhooks/stripe
# Événements utiles : payment_intent.succeeded, payment_intent.payment_failed,
# invoice.paid, customer.subscription.updated, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=

# Prix Stripe récurrents « une fois par semaine » (cours à la carte : 10 € / 8 € / 5 €)
# Créez 3 produits/prix en mode récurrent, intervalle hebdomadaire, montants 10, 8 et 5 EUR.
STRIPE_PRICE_WEEKLY_60=
STRIPE_PRICE_WEEKLY_40=
STRIPE_PRICE_WEEKLY_30=

# URL publique du site (liens dans les e-mails — ex. https://votredomaine.fr)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# WhatsApp — tableau de bord élève (chiffres uniquement, indicatif pays sans + ni espaces)
# Ex. France : 33612345678 pour +33 6 12 34 56 78
NEXT_PUBLIC_WHATSAPP_FEMMES=
NEXT_PUBLIC_WHATSAPP_HOMMES=

# ========== Resend (e-mails après achat : identifiants + guide « prochaines étapes ») ==========
RESEND_API_KEY=
# Expéditeur : OBLIGATOIRE en production vers de vrais clients.
# Format : "ArabeSimplement <no-reply@votredomaine.fr>" (domaine vérifié dans Resend → Domains).
# Sans domaine vérifié, Resend n’autorise que des tests avec l’expéditeur par défaut
# onboarding@resend.dev — et UNIQUEMENT en destinataire l’e-mail du compte Resend (pas admin@… ni clients).
# Si vous voyez 403 "You can only send testing emails to your own email address" : vérifiez le domaine,
# puis renseignez RESEND_FROM avec une adresse @votredomaine.fr et redéployez.
RESEND_FROM=

# ========== Supabase (auth prévue — optionnel tant que vous utilisez le mock) ==========
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ========== Cloudinary (images des formations — optionnel, sinon fichiers locaux public/uploads) ==========
# Console : https://cloudinary.com/console → « API Keys » ou bannière du tableau de bord.
# CLOUDINARY_CLOUD_NAME = « Cloud name » (court, ex. dabc123xy) — ce n’est ni la clé API ni l’URL du site.
# CLOUDINARY_API_KEY = nombre (souvent 10–15 chiffres)
# CLOUDINARY_API_SECRET = chaîne longue secrète (ne jamais l’exposer côté client)
# Sur Vercel : ajouter les 3 variables pour le projet, redéployer après modification.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
