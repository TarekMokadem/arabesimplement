# --- Copiez ce fichier en .env et renseignez les valeurs.
#    Ne commitez jamais le fichier .env (déjà dans .gitignore).

# ========== Prisma / PostgreSQL (obligatoire pour données réelles) ==========
# Exemple local : postgresql://USER:PASSWORD@localhost:5432/NOM_BASE?schema=public
# Hébergé gratuit : Neon (neon.tech), Supabase (Database > Connection string), etc.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/arabesimplement?schema=public"

# ========== Session / auth maison (obligatoire avec DATABASE_URL) ==========
# Chaîne secrète d'au moins 32 caractères (ex. openssl rand -base64 32)
SESSION_SECRET=

# Compte admin créé/mis à jour au seed (optionnel)
# ADMIN_SEED_EMAIL=admin@votredomaine.fr
# ADMIN_SEED_PASSWORD=

# ========== Next.js ==========
# Rien à ajouter : Next charge automatiquement .env en local.

# ========== Stripe (paiement réel — optionnel au début) ==========
# Tableau de bord : https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhooks : Developers > Webhooks > endpoint URL .../api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=

# URL publique du site (liens dans les e-mails — ex. https://votredomaine.fr)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ========== Resend (e-mail compte créé après achat invité) ==========
RESEND_API_KEY=
# Expéditeur vérifié chez Resend, ex. "ArabeSimplement <contact@votredomaine.fr>"
RESEND_FROM=

# ========== Supabase (auth prévue — optionnel tant que vous utilisez le mock) ==========
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
