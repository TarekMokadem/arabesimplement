generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum UserRole {
  STUDENT
  ADMIN
}

/** Lien e-mail : mot de passe oublié (public) ou changement demandé depuis l’espace élève. */
enum PasswordResetPurpose {
  FORGOT
  CHANGE
}

/** Pour orienter l’élève vers le bon interlocuteur WhatsApp (équipe féminine / masculine). */
enum StudentSex {
  FEMME
  HOMME
}

enum FormationStatus {
  ACTIVE
  INACTIVE
  COMING_SOON
  ARCHIVED
}

/** Domaine principal affiché en boutique (pack mixte = les deux). */
enum FormationTheme {
  ARABE
  RELIGION
  MIX
}

/** Mode d'organisation : heures à la carte, formation flexible, ou créneaux fixes. */
enum FormationSchedulingMode {
  HOURLY_PURCHASE
  FLEXIBLE_FORMATION
  FIXED_SLOTS
}

enum CreneauStatus {
  OPEN
  FULL
  CLOSED
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

/** Compte PayPal.me actif pour les virements directs (hors Stripe Checkout). */
enum PaypalMeRecipient {
  YACINE_BOU18
  JANA_OKF
}

/** Abonnement hebdo cours à la carte (Stripe). */
enum WeeklySubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELED
  PAST_DUE
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  prenom       String
  nom          String
  telephone    String?
  sexe         StudentSex? @map("sexe")
  passwordHash String?   @map("password_hash")
  /** Client Stripe (abonnements cours à la carte). */
  stripeCustomerId String? @unique @map("stripe_customer_id")
  role         UserRole  @default(STUDENT)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  orders                 Order[]
  enrollments            Enrollment[]
  courseWeeklySubscriptions CourseWeeklySubscription[]
  passwordResetTokens    PasswordResetToken[]

  @@map("users")
}

model PasswordResetToken {
  id        String               @id @default(uuid())
  userId    String               @map("user_id")
  tokenHash String               @map("token_hash")
  purpose   PasswordResetPurpose
  expiresAt DateTime             @map("expires_at")
  usedAt    DateTime?            @map("used_at")
  createdAt DateTime             @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId])
  @@map("password_reset_tokens")
}

model Formation {
  id                String          @id @default(uuid())
  titre             String
  slug              String          @unique
  descriptionCourte String          @map("description_courte")
  description       String?         @db.Text
  prix              Decimal         @db.Decimal(10, 2)
  prixPromo         Decimal?        @map("prix_promo") @db.Decimal(10, 2)
  imageUrl          String?         @map("image_url")
  placesMax         Int?            @map("places_max")
  theme             FormationTheme  @default(ARABE) @map("theme")
  schedulingMode    FormationSchedulingMode @default(FIXED_SLOTS) @map("scheduling_mode")
  statut            FormationStatus @default(ACTIVE)
  featured          Boolean         @default(false)
  featuredContent   String?         @map("featured_content") @db.Text
  featuredTitre     String?         @map("featured_titre")
  featuredBadge     String?         @map("featured_badge")
  featuredExpiresAt DateTime?       @map("featured_expires_at")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  creneaux                   Creneau[]
  orderItems                 OrderItem[]
  enrollments                Enrollment[]
  courseWeeklySubscriptions CourseWeeklySubscription[]

  @@map("formations")
}

model Creneau {
  id            String        @id @default(uuid())
  formationId   String        @map("formation_id")
  nom           String
  jours         String[]
  /** Détail par jour : heure et durée propres à chaque jour (JSON). Les champs jours/heureDebut/dureeMinutes restent pour compatibilité et requêtes simples. */
  journeeSlots  Json?         @map("journee_slots")
  heureDebut    String        @map("heure_debut")
  dureeMinutes  Int           @map("duree_minutes")
  placesMax     Int           @map("places_max")
  whatsappLink  String?       @map("whatsapp_link")
  statut        CreneauStatus @default(OPEN)
  createdAt     DateTime      @default(now()) @map("created_at")

  formation                  Formation                  @relation(fields: [formationId], references: [id], onDelete: Cascade)
  enrollments                Enrollment[]
  orderItems                 OrderItem[]
  courseWeeklySubscriptions CourseWeeklySubscription[]

  @@map("creneaux")
}

model Order {
  id                    String      @id @default(uuid())
  /** Null tant que la commande invité n’est pas payée ; ensuite rattaché à l’utilisateur créé ou existant. */
  userId                String?     @map("user_id")
  /** Données de facturation saisies au checkout (toujours renseigné en base). */
  billingSnapshot       Json?       @map("billing_snapshot")
  total                 Decimal     @db.Decimal(10, 2)
  statut                OrderStatus @default(PENDING)
  stripePaymentIntentId String?     @unique @map("stripe_payment_intent_id")
  /** Client Stripe créé pour le tunnel (invité inclus, recopié sur User après paiement). */
  stripeCustomerId      String?     @map("stripe_customer_id")
  /** Abonnement hebdo (cours à la carte — plusieurs lignes = un seul Subscription Stripe). */
  stripeSubscriptionId  String?     @unique @map("stripe_subscription_id")
  reglementSigneAt      DateTime?   @map("reglement_signe_at")
  reglementIp           String?     @map("reglement_ip")
  reglementVersion      String?     @map("reglement_version")
  /** Évite l’envoi en double de l’e-mail de bienvenue ou du guide « prochaines étapes ». */
  purchaseFollowupEmailSentAt DateTime? @map("purchase_followup_email_sent_at")
  createdAt             DateTime    @default(now()) @map("created_at")

  user                     User?                     @relation(fields: [userId], references: [id])
  orderItems               OrderItem[]
  courseWeeklySubscriptions CourseWeeklySubscription[]

  @@map("orders")
}

model OrderItem {
  id            String  @id @default(uuid())
  orderId       String  @map("order_id")
  formationId   String  @map("formation_id")
  creneauId     String? @map("creneau_id")
  hourlyMinutes Int?    @map("hourly_minutes")
  /** Pour cours à la carte : nombre de « unités » de cette durée facturées chaque semaine (ex. 2 × 1 h). */
  hourlyQuantity Int    @default(1) @map("hourly_quantity")
  /** Identifiant stable de ligne panier (abonnement Stripe / rattachement des metadata). */
  cartLineId    String? @map("cart_line_id")
  prixUnitaire  Decimal @map("prix_unitaire") @db.Decimal(10, 2)

  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  formation Formation @relation(fields: [formationId], references: [id])
  creneau   Creneau?  @relation(fields: [creneauId], references: [id], onDelete: SetNull)

  @@map("order_items")
}

model Enrollment {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  formationId    String    @map("formation_id")
  creneauId      String?   @map("creneau_id")
  token          String    @unique @default(uuid())
  tokenExpiresAt DateTime  @map("token_expires_at")
  tokenUsed      Boolean   @default(false) @map("token_used")
  /** Renseigné par l’admin : professeur assigné (affiché dans l’espace élève). */
  assignedProfessorName String? @map("assigned_professor_name")
  /** Lien ou numéro WhatsApp du groupe de cours (wa.me/…, https://chat.whatsapp.com/…). */
  assignedWhatsappUrl   String? @map("assigned_whatsapp_url") @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")

  user      User       @relation(fields: [userId], references: [id])
  formation Formation  @relation(fields: [formationId], references: [id])
  creneau   Creneau?   @relation(fields: [creneauId], references: [id])

  @@map("enrollments")
}

/** Une ligne d’abonnement hebdomadaire (cours à la carte) liée à Stripe SubscriptionItem. */
model CourseWeeklySubscription {
  id                       String                   @id @default(uuid())
  userId                   String                   @map("user_id")
  orderId                  String?                  @map("order_id")
  formationId              String                   @map("formation_id")
  creneauId                String?                  @map("creneau_id")
  hourlyMinutes            Int                      @map("hourly_minutes")
  /** Aligné sur la quantity du SubscriptionItem Stripe (unités / semaine pour cette durée). */
  bundleQuantity           Int                      @default(1) @map("bundle_quantity")
  stripeSubscriptionId     String                   @map("stripe_subscription_id")
  stripeSubscriptionItemId String?                  @unique @map("stripe_subscription_item_id")
  status                   WeeklySubscriptionStatus @default(ACTIVE)
  currentPeriodEnd         DateTime?                @map("current_period_end")
  createdAt                DateTime                 @default(now()) @map("created_at")
  updatedAt                DateTime                 @updatedAt @map("updated_at")

  user      User      @relation(fields: [userId], references: [id])
  formation Formation @relation(fields: [formationId], references: [id])
  creneau   Creneau?  @relation(fields: [creneauId], references: [id])
  order     Order?    @relation(fields: [orderId], references: [id])

  @@map("course_weekly_subscriptions")
}

model ReglementInterieur {
  id        String   @id @default(uuid())
  contenu   String   @db.Text
  version   String
  actif     Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("reglement_interieur")
}

model Testimonial {
  id        String   @id @default(uuid())
  nom       String
  texte     String   @db.Text
  note      Int
  approuve  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("testimonials")
}

model BlogPost {
  id          String   @id @default(uuid())
  titre       String
  slug        String   @unique
  contenu     String   @db.Text
  imageUrl    String?  @map("image_url")
  publie      Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("blog_posts")
}

model ContactMessage {
  id        String   @id @default(uuid())
  nom       String
  email     String
  telephone String?
  sujet     String
  message   String   @db.Text
  lu        Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("contact_messages")
}

/** Configuration globale (singleton id = global). */
model SiteConfig {
  id                  String            @id
  paypalMeRecipient   PaypalMeRecipient @default(YACINE_BOU18) @map("paypal_me_recipient")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  @@map("site_config")
}
